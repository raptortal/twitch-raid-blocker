{
  "manifest_version": 3,
  "name": "Котикс Блочит — Twitch Raid Blocker",
  "version": "2.1.2",
  "description": "Автоматически отменяет рейды на Twitch. Больше никаких неожиданных перенаправлений.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"    
    }
  },
  "icons": {
    "16": "icons/icon-16.jpg",
    "32": "icons/icon-32.jpg",
    "48": "icon.png",
    "64": "icons/icon-64.jpg"
  }
}